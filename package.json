{
  "name": "zooffice",
  "version": "0.1.0",
  "description": "Agent orchestration framework — an office of animals",
  "type": "module",
  "bin": {
    "zooffice": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:server": "node --loader ts-node/esm src/server/index.ts",
    "start:client": "node --loader ts-node/esm src/client/index.ts",
    "start:renderer": "node --loader ts-node/esm src/renderer/index.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ws": "^8.18.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ts-node": "^10.9.2"
  }
}
